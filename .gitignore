# Persistent agent state (qualitative business memory — confidential)
state/

# Email credentials
tools/email/email-config.json

# HubSpot Private App token (Phase 2 leads sync)
tools/hubspot/hubspot-config.json

# Google Sheets service-account credentials + workbook config (live edit
